{
  "name": "kubek-minecraft-dashboard",
  "version": "3.0.8",
  "description": "Веб-панель управления серверами Minecraft",
  "main": "app.js",
  "keywords": [
    "minecraft",
    "dashboard",
    "admin-panel",
    "web-ui",
    "server-management"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Khim-khaos",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "build": "pkg --config pkgconfig.json app.js",
    "dockerBuild": "docker build -t Khim-khaos/kubek-minecraft-dashboard .",
    "dockerPush": "docker push Khim-khaos/kubek-minecraft-dashboard",
    "lint": "eslint .",
    "swagger": "node swagger.js",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Khim-khaos/kubek-minecraft-dashboard"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "axios": "^1.7.9",
    "colors": "^1.4.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "crypto-js": "^4.2.0",
    "decompress": "^4.2.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-fileupload": "^1.5.1",
    "express-rate-limit": "^8.5.1",
    "ftp-srv-esm": "^5.0.1",
    "helmet": "^8.1.0",
    "http-proxy-agent": "^8.0.0",
    "https-proxy-agent": "^8.0.0",
    "iconv-lite": "^0.7.2",
    "is-in-subnet": "^4.0.1",
    "jimp": "^0.22.12",
    "js-base64": "^3.7.7",
    "mime": "^3.0.0",
    "minecraft-server-properties": "^1.0.0",
    "node-disk-info": "^1.3.0",
    "node-machine-id": "^1.1.12",
    "node-mcstatus": "^1.2.1",
    "os-utils": "^0.0.14",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0"
  }
}
